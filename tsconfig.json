{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "target": "ES2022",
    "types": ["svelte"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.ts"]
}
